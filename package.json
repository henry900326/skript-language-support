{
  "name": "skript-language-support",
  "displayName": "Skript Language Support",
  "description": "Skript syntax highlighting for VS Code",
  "version": "0.0.1",
  "publisher": "henry900326",

  "engines": {
    "vscode": "^1.110.0"
  },

  "license": "MIT",

  "repository": {
    "type": "git",
    "url": "https://github.com/henry900326/skript-language-support"
  },

  "bugs": {
    "url": "https://github.com/henry900326/skript-language-support/issues"
  },

  "categories": [
    "Programming Languages"
  ],

  "contributes": {
    "languages": [
      {
        "id": "skript",
        "aliases": ["Skript"],
        "extensions": [".sk"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "skript",
        "scopeName": "source.skript",
        "path": "./syntaxes/skript.tmLanguage.json"
      }
    ]
  }
}